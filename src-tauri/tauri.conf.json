{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri/next/.schema/config.schema.json",
  "productName": "Contextura",
  "version": "1.0.0",
  "identifier": "com.contextura.app",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay-main",
        "title": "",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "fullscreen": false,
        "maximized": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "externalBin": [
      "binaries/llama-server",
      "binaries/vision-helper"
    ],
    "resources": [
      "binaries/*.dylib"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/contextura/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
